# Secrets des edge functions à recopier sur le NOUVEAU projet.
# Copie ce fichier en .migration/functions-secrets.env et remplis les valeurs
# (depuis Lovable Cloud → onglet Secrets). CE FICHIER N'EST JAMAIS COMMITTÉ.
# Je lancerai :  supabase secrets set --env-file .migration/functions-secrets.env
# Laisse vide / supprime les lignes des secrets que tu n'utilises pas.
#
# --- IA (critiques pour le nouveau câblage) ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# --- Email ---
RESEND_API_KEY=
BREVO_API_KEY=
INSTANTLY_API_KEY=
# --- Paiement ---
