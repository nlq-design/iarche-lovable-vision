# Secrets edge functions à recopier sur le NOUVEAU projet (liste réelle de
# l'ancien projet, 27 secrets — LOVABLE_API_KEY exclu, plus nécessaire).
# Copie ce fichier en .migration/functions-secrets.env et colle les valeurs
# (depuis Lovable Cloud → onglet Secrets : révèle chaque valeur, copie-colle).
# CE FICHIER N'EST JAMAIS COMMITTÉ. Je lancerai :
#   supabase secrets set --env-file .migration/functions-secrets.env
#
# Astuce JSON (GOOGLE_SERVICE_ACCOUNT_KEY) : mets toute la valeur sur UNE seule
# ligne, entre guillemets simples : GOOGLE_SERVICE_ACCOUNT_KEY='{"type":...}'
#
# --- IA ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
# --- Email ---
RESEND_API_KEY=
BREVO_API_KEY=
INSTANTLY_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
# --- Paiement ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# --- Transcription / data ---
ASSEMBLYAI_API_KEY=
PAPPERS_API_KEY=
ILOVEPDF_PUBLIC_KEY=
ILOVEPDF_SECRET_KEY=
# --- Google / Zoom ---
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_CALENDAR_ID=
GOOGLE_SEARCH_CONSOLE_API_KEY=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# --- Infra ---
FLY_API_TOKEN=
OWNER_WORKSPACE_ID=
#
# --- Optionnels (référencés dans le code mais ABSENTS de l'ancien projet —
#     définis-les si besoin, sinon laisse vide) ---
# SITE_URL=https://...            # base des liens d'invitation (sinon fallback .lovable.app)
# DEFAULT_WORKSPACE_ID=
# SEND_EMAIL_HOOK_SECRET=         # uniquement si tu configures l'Auth Email Hook
